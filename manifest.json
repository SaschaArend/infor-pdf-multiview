{
  "manifest_version": 3,
  "name": "INFOR - PDF Multiview",
  "version": "2025.11.0",
  "description": "PDF Multiview for INFOR Invoice Process",
  "permissions": [
    "webRequest",
    "tabs"
  ],
  "host_permissions": [
    "*://*.inforcloudsuite.com/*"
  ],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.inforcloudsuite.com/*"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "intercept.js"
      ],
      "matches": [
        "*://*.inforcloudsuite.com/*"
      ]
    }
  ]
}